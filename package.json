{
  "name": "vllm-i64",
  "version": "0.5.2",
  "description": "TypeScript SDK for vllm-i64 — integer-first inference engine",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "node --test dist/test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vllm",
    "i64",
    "inference",
    "llm",
    "moe",
    "openai",
    "ai",
    "complexity",
    "search",
    "perplexity",
    "security"
  ],
  "author": "Complexity-ML / INL",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Complexity-ML/vllm-i64-sdk"
  },
  "homepage": "https://github.com/Complexity-ML/vllm-i64-sdk",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
